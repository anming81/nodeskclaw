# ── ClawBuddy 环境变量 ──

# App
DEBUG=true

# Database（PostgreSQL）
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/clawbuddy

# JWT — 生产环境务必替换
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# KubeConfig 加密密钥（32 字节 base64）
ENCRYPTION_KEY=change-me-32-bytes-base64-key__=

# 飞书 SSO
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:5173/api/v1/auth/feishu/callback

# 云平台
VKE_SUBNET_ID=
IMAGE_REGISTRY=

# CORS
CORS_ORIGINS=["http://localhost:5173"]
